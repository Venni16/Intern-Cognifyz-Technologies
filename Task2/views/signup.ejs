<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <style>
      btn:hover{
       background-color: blue;
      }
     </style>
 </head>
 <body style="background:linear-gradient(to bottom right, #007BFF, #000000); display: flex;justify-content: center;align-items: center;">
  <% if (error && error.length > 0) { %>
    <div id="errorBox" style="position: absolute; top: 10px; right: 10px; background-color: red; color: white;
     padding: 15px; border-radius: 5px; opacity: 1; transition: opacity 1s ease;">
      <%= error %> </div> <% } %>

   <div style=" background-color: white; font-family:Cambria, Cochin, Georgia, Times, 'Times New Roman', serif;border-color: rgb(15, 75, 154); border-style: solid;border-width: 4px;border-radius: 15px;width: 420px;height: 480px;display: flexbox;justify-content: center;">
     
     <h1 style="font-size:xx-large; padding-left: 160px;padding-top: 30px; font-family:'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif; color:rgb(8, 41, 86);">Register</h1>
   
     <form action="/signup" method="POST" onsubmit="handleSignup()" >
        <div style="margin: 10px;margin-top: 45px;">

          <div style="margin-bottom: 5%;">
            <label style="display: block;"  for="name">Name:</label>
            <input style="font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif; border-color: rgb(1, 86, 197);  padding: 8px;width: 100%;" type="name" id="name" name="name" required>
          </div>
           <div style="margin-bottom: 5%;">
             <label style="display: block;" for="email">Email:</label>
             <input style="font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif; border-color: rgb(1, 86, 197); padding: 8px;width: 100%;" type="email" id="email" name="email" required>
           </div>
           <div style="margin-bottom: 5%;">
             <label style="display: block;"  for="password">Password:</label>
             <input style="font-family: 'Trebuchet MS', 'Lucida Sans Unicode', 'Lucida Grande', 'Lucida Sans', Arial, sans-serif; border-color: rgb(1, 86, 197);  padding: 8px;width: 100%;" type="password" id="password" name="password" required>
           </div>
 
           <div style="margin-top: 20px;">
             <button class="btn" onmouseover="this.style.backgroundColor='#0056b3';this.style.transform='scale(1.02)'"
             onmouseout="this.style.backgroundColor='rgb(71, 99, 169)'; this.style.transform='scale(1)'"  style=" transition: all 0.3s ease; cursor: pointer;width: 100%; border-radius: 5px; padding: 10px 20px; background-color: rgb(71, 99, 169);margin-top: 10px;margin-left: 2px; color: white;font-size:medium; " type="submit">Register</button>
           </div>
           <div style="margin-top: 1rem;font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
             <p>Already have an Account?<a style="text-decoration: none;" href="/login">signin</a></p>
           </div>
        </div>
     </form>
   </div>
    <script>




function handleSignup() {
            const name = document.getElementById("name").value.trim();
            const email = document.getElementById("email").value.trim();
            const password= document.getElementById("password").value.trim();


            if (!name || ! email || ! password) {
                alert("All fields are required.")
                return false;
            }
            return true;
            
}
     
           

          
   

            
    </script>
</body>
</html>