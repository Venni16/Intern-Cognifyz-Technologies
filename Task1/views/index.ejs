<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body style=" background-color: #f4f4f4; display: flex; flex-direction: column;justify-content: center;align-items: center;">
  <div style="font-family: Arial;padding: 20px;margin-top: 15%;">
    <h1 style="color: #333;">USER REGISTRATION FORM</h1>

    <form action="/submit" method="POST">
          <div style="margin: 2px;margin-bottom: 4px;">
            <label for="name">Name:</label>
            <input style="width: 100%; padding: 8px;" type="text" id="name" name="name" required>
          </div>

          <div style="margin: 3px;margin-bottom: 4px;">
            <label for="email">Email:</label>
            <input style="width: 100%; padding: 8px;" type="email" id="email" name="email" required>
          </div>

          <div>
            <button style="padding: 10px 20px; background: green;margin-top: 5px;margin-left: 2px; color: white;" type="submit">Submit</button>
          </div>
    </form>
  </div>
</body>
</html>